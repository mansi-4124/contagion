# ==============================================================================
# 1. ENVIRONMENT VARIABLES & SECRETS (NEVER COMMIT THESE)
# ==============================================================================
.env
.env.*
!.env.example
secrets.json
*.pem
*.key

# ==============================================================================
# 2. PYTHON ENGINE & CACHING BUILD ARTIFACTS
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
pip-log.txt
pip-delete-this-directory.txt

# ==============================================================================
# 3. VIRTUAL ENVIRONMENTS (DEPENDENCY COPIES)
# ==============================================================================
venv/
.venv/
env/
.env/
ENV/
pyenv/
.python-version

# ==============================================================================
# 4. FRONTEND SYSTEM (NODE / VITE / REACT)
# ==============================================================================
node_modules/
/frontend/node_modules/
/frontend/dist/
/frontend/build/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==============================================================================
# 5. EMBEDDED DATABASES & LOCAL VECTOR STORAGE (CRITICAL FOR YOUR STACK)
# ==============================================================================
# Kuzu DB local file persistence directories
kuzu_db/
*.kuzu

# FastEmbed local model downloads and local vector store outputs
.fastembed_cache/
fastembed_cache/
lancedb/
.lancedb/

# Local database volumes (if you run PG/Redis via docker-compose locally)
pgdata/
redisdata/

# ==============================================================================
# 6. SYSTEM FILES & OPERATIONAL LOGS
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.log
logs/
celerybeat-schedule
celerybeat-schedule.db

