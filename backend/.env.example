# --- DatabaseSettings (env_prefix=DB_) ---
DB_URL=
DB_POOL_SIZE=10

# --- CogneeSettings (env_prefix=COGNEE_) ---
COGNEE_API_KEY=
COGNEE_DEFAULT_SCHEMA_VERSION=1

# --- RedisSettings (env_prefix=REDIS_) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# --- LLMSettings (Groq via LLM_ prefix) ---
LLM_PROVIDER=custom
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# --- EmailSettings (env_prefix=EMAIL_) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=

# --- ClerkSettings (env_prefix=CLERK_) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- SchedulerSettings (env_prefix=SCHEDULER_) ---
SCHEDULER_ALERT_CYCLE_INTERVAL_MINUTES=15
SCHEDULER_OUTCOME_VALIDATION_DELAY_DAYS=30

# --- Auth fallback (only used if Clerk isn't wired up yet — Tech Decisions §3 fallback note) ---
JWT_SECRET=
JWT_ALGORITHM=HS256